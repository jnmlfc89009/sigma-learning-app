{
  "part1": "\n        <div id=\"sublime-themed-vault-card\" className=\"bg-white border border-slate-200 rounded-[32px] p-6 space-y-6 text-left animate-pop\">\n          <div className=\"flex flex-col md:flex-row items-start md:items-center justify-between gap-4 border-b border-slate-100 pb-4\">\n            <div className=\"space-y-1 max-w-2xl\">\n              <span className=\"text-[9px] bg-emerald-50 border border-emerald-200 text-emerald-700 px-2.5 py-1 rounded-full font-bold uppercase tracking-wider font-mono flex items-center gap-1 w-fit\">\n                <Trophy className=\"w-3.5 h-3.5 text-emerald-600 fill-emerald-500\" />\n                Themed Reward Vault\n              </span>\n              <h3 className=\"font-display font-black text-2xl text-slate-900 tracking-tight\">\n                Sublime Gem Trade-Up Vault\n              </h3>\n              <p className=\"text-slate-500 text-xs\">\n                Provide yourself with long-term academic milestones. Convert standard accumulated gems into prestigious Rare and Legendary tokens. Displays prominently inside your trophy cabinets.\n              </p>\n            </div>\n\n            {/* Display collected items summary cabinet */}\n            <div className=\"bg-slate-50 border border-slate-200 rounded-2xl p-4 flex gap-4 text-center\">\n              <div>\n                <span className=\"text-[8px] font-bold text-slate-400 block uppercase font-mono\">Jade</span>\n                <span className=\"font-mono text-base font-black text-emerald-600\">\n                  {user.unlockedItems?.filter(x => x === 'trophy_gem_jade').length || 0}x\n                </span>\n              </div>\n              <div className=\"border-l border-slate-200\"></div>\n              <div>\n                <span className=\"text-[8px] font-bold text-slate-400 block uppercase font-mono\">Sapphire</span>\n                <span className=\"font-mono text-base font-black text-blue-600\">\n                  {user.unlockedItems?.filter(x => x === 'trophy_gem_sapphire').length || 0}x\n                </span>\n              </div>\n              <div className=\"border-l border-slate-200\"></div>\n              <div>\n                <span className=\"text-[8px] font-bold text-slate-400 block uppercase font-mono\">Ruby</span>\n                <span className=\"font-mono text-base font-black text-rose-600\">\n                  {user.unlockedItems?.filter(x => x === 'trophy_gem_ruby').length || 0}x\n                </span>\n              </div>\n              <div className=\"border-l border-slate-200\"></div>\n              <div>\n                <span className=\"text-[8px] font-bold text-slate-400 block uppercase font-mono\">Obsidian</span>\n                <span className=\"font-mono text-base font-black text-purple-650\">\n                  {user.unlockedItems?.filter(x => x === 'trophy_gem_obsidian').length || 0}x\n                </span>\n              </div>\n            </div>\n          </div>\n\n          {vaultSuccess && (\n            <div className=\"p-4 bg-emerald-50 border border-emerald-200 text-emerald-800 rounded-2xl text-xs flex items-center gap-2.5 animate-pop\">\n              <ShieldCheck className=\"w-5 h-5 text-emerald-600 flex-shrink-0\" />\n              <span className=\"font-semibold\">{vaultSuccess}</span>\n            </div>\n          )}\n\n          {vaultError && (\n            <div className=\"p-4 bg-rose-50 border border-rose-200 text-rose-800 rounded-2xl text-xs flex items-center gap-2.5 animate-pop\">\n              <AlertCircle className=\"w-5 h-5 text-rose-600 flex-shrink-0\" />\n              <span className=\"font-semibold\">{vaultError}</span>\n            </div>\n          )}\n\n          <div className=\"grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-4 pt-1\">\n            {tradeTiers.map(tier => {\n              const count = user.unlockedItems?.filter(x => x === tier.id).length || 0;\n              const hasBoughtBadge = count > 0;\n              const canAfford = user.gems >= tier.price;\n\n              return (\n                <div\n                  key={tier.id}\n                  className={`p-4 border rounded-2xl flex flex-col justify-between gap-4 transition-all duration-200 ${tier.bgColor} ${\n                    hasBoughtBadge ? \"shadow-sm border-slate-300\" : \"border-slate-205 bg-white\"\n                  }`}\n                >\n                  <div className=\"space-y-2\">\n                    <div className=\"flex items-center justify-between gap-2\">\n                      <span className=\"text-[8px] font-mono font-bold bg-slate-100 text-slate-600 px-1.5 py-0.5 rounded truncate\">\n                        {tier.badge}\n                      </span>\n                      <span className=\"font-mono text-[9px] font-bold bg-slate-105 text-slate-500 px-1.5 py-0.5 rounded shrink-0\">\n                        Owned: {count}\n                      </span>\n                    </div>\n\n                    <div className=\"flex gap-2 items-center\">\n                      <Gem className={`w-6 h-6 shrink-0 ${tier.iconColor}`} />\n                      <h4 className=\"font-display font-black text-[11px] text-slate-900 uppercase\">\n                        {tier.name}\n                      </h4>\n                    </div>\n\n                    <p className=\"text-slate-500 text-[10px] leading-relaxed\">\n                      {tier.desc}\n                    </p>\n                  </div>\n\n                  <div className=\"pt-2 border-t border-slate-100 flex flex-col gap-2\">\n                    <button\n                      type=\"button\"\n                      onClick={() => tradeTrophiesGems(tier)}\n                      disabled={vaultLoading !== null || !canAfford}\n                      className={`w-full py-2 text-[10px] font-extrabold font-mono uppercase tracking-wider rounded-xl transition flex items-center justify-center gap-1 border-b-2 cursor-pointer ${\n                        !canAfford\n                          ? \"bg-stone-50 border-stone-200 text-stone-400 cursor-not-allowed border-b\"\n                          : \"bg-amber-50 hover:bg-amber-100 text-amber-700 border-amber-200\"\n                      }`}\n                    >\n                      {vaultLoading === tier.id ? (\n                        <RefreshCw className=\"w-3 h-3 animate-spin\" />\n                      ) : (\n                        <>\n                          <Coins className=\"w-3.5 h-3.5 text-amber-600 fill-amber-500\" />\n                          Trade {tier.price} 💎\n                        </>\n                      )}\n                    </button>\n                  </div>\n                </div>\n              );\n            })}\n          </div>\n        \n\n        ",
  "part2": "\n        <div id=\"sublime-themed-vault-card\" className=\"bg-white border border-slate-200 rounded-[32px] p-6 space-y-6 text-left animate-pop\">\n          <div className=\"flex flex-col md:flex-row items-start md:items-center justify-between gap-4 border-b border-slate-100 pb-4\">\n            <div className=\"space-y-1 max-w-2xl\">\n              <span className=\"text-[9px] bg-emerald-50 border border-emerald-200 text-emerald-700 px-2.5 py-1 rounded-full font-bold uppercase tracking-wider font-mono flex items-center gap-1 w-fit\">\n                <Trophy className=\"w-3.5 h-3.5 text-emerald-600 fill-emerald-500\" />\n                Themed Reward Vault\n              </span>\n              <h3 className=\"font-display font-black text-2xl text-slate-900 tracking-tight\">\n                Sublime Gem Trade-Up Vault\n              </h3>\n              <p className=\"text-slate-500 text-xs\">\n                Provide yourself with long-term academic milestones. Convert standard accumulated gems into prestigious Rare and Legendary tokens. Displays prominently inside your trophy cabinets.\n              </p>\n            </div>\n\n            {/* Display collected items summary cabinet */}\n            <div className=\"bg-slate-50 border border-slate-200 rounded-2xl p-4 flex gap-4 text-center\">\n              <div>\n                <span className=\"text-[8px] font-bold text-slate-400 block uppercase font-mono\">Jade</span>\n                <span className=\"font-mono text-base font-black text-emerald-600\">\n                  {user.unlockedItems?.filter(x => x === 'trophy_gem_jade').length || 0}x\n                </span>\n              </div>\n              <div className=\"border-l border-slate-200\"></div>\n              <div>\n                <span className=\"text-[8px] font-bold text-slate-400 block uppercase font-mono\">Sapphire</span>\n                <span className=\"font-mono text-base font-black text-blue-600\">\n                  {user.unlockedItems?.filter(x => x === 'trophy_gem_sapphire').length || 0}x\n                </span>\n              </div>\n              <div className=\"border-l border-slate-200\"></div>\n              <div>\n                <span className=\"text-[8px] font-bold text-slate-400 block uppercase font-mono\">Ruby</span>\n                <span className=\"font-mono text-base font-black text-rose-600\">\n                  {user.unlockedItems?.filter(x => x === 'trophy_gem_ruby').length || 0}x\n                </span>\n              </div>\n              <div className=\"border-l border-slate-200\"></div>\n              <div>\n                <span className=\"text-[8px] font-bold text-slate-400 block uppercase font-mono\">Obsidian</span>\n                <span className=\"font-mono text-base font-black text-purple-650\">\n                  {user.unlockedItems?.filter(x => x === 'trophy_gem_obsidian').length || 0}x\n                </span>\n              </div>\n            </div>\n          </div>\n\n          {vaultSuccess && (\n            <div className=\"p-4 bg-emerald-50 border border-emerald-200 text-emerald-800 rounded-2xl text-xs flex items-center gap-2.5 animate-pop\">\n              <ShieldCheck className=\"w-5 h-5 text-emerald-600 flex-shrink-0\" />\n              <span className=\"font-semibold\">{vaultSuccess}</span>\n            </div>\n          )}\n\n          {vaultError && (\n            <div className=\"p-4 bg-rose-50 border border-rose-200 text-rose-800 rounded-2xl text-xs flex items-center gap-2.5 animate-pop\">\n              <AlertCircle className=\"w-5 h-5 text-rose-600 flex-shrink-0\" />\n              <span className=\"font-semibold\">{vaultError}</span>\n            </div>\n          )}\n\n          <div className=\"grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-4 pt-1\">\n            {tradeTiers.map(tier => {\n              const count = user.unlockedItems?.filter(x => x === tier.id).length || 0;\n              const hasBoughtBadge = count > 0;\n              const canAfford = user.gems >= tier.price;\n\n              return (\n                <div\n                  key={tier.id}\n                  className={`p-4 border rounded-2xl flex flex-col justify-between gap-4 transition-all duration-200 ${tier.bgColor} ${\n                    hasBoughtBadge ? \"shadow-sm border-slate-300\" : \"border-slate-205 bg-white\"\n                  }`}\n                >\n                  <div className=\"space-y-2\">\n                    <div className=\"flex items-center justify-between gap-2\">\n                      <span className=\"text-[8px] font-mono font-bold bg-slate-100 text-slate-600 px-1.5 py-0.5 rounded truncate\">\n                        {tier.badge}\n                      </span>\n                      <span className=\"font-mono text-[9px] font-bold bg-slate-105 text-slate-500 px-1.5 py-0.5 rounded shrink-0\">\n                        Owned: {count}\n                      </span>\n                    </div>\n\n                    <div className=\"flex gap-2 items-center\">\n                      <Gem className={`w-6 h-6 shrink-0 ${tier.iconColor}`} />\n                      <h4 className=\"font-display font-black text-[11px] text-slate-900 uppercase\">\n                        {tier.name}\n                      </h4>\n                    </div>\n\n                    <p className=\"text-slate-500 text-[10px] leading-relaxed\">\n                      {tier.desc}\n                    </p>\n                  </div>\n\n                  <div className=\"pt-2 border-t border-slate-100 flex flex-col gap-2\">\n                    <button\n                      type=\"button\"\n                      onClick={() => tradeTrophiesGems(tier)}\n                      disabled={vaultLoading !== null || !canAfford}\n                      className={`w-full py-2 text-[10px] font-extrabold font-mono uppercase tracking-wider rounded-xl transition flex items-center justify-center gap-1 border-b-2 cursor-pointer ${\n                        !canAfford\n                          ? \"bg-stone-50 border-stone-200 text-stone-400 cursor-not-allowed border-b\"\n                          : \"bg-amber-50 hover:bg-amber-100 text-amber-700 border-amber-200\"\n                      }`}\n                    >\n                      {vaultLoading === tier.id ? (\n                        <RefreshCw className=\"w-3 h-3 animate-spin\" />\n                      ) : (\n                        <>\n                          <Coins className=\"w-3.5 h-3.5 text-amber-600 fill-amber-500\" />\n                          Trade {tier.price} 💎\n                        </>\n                      )}\n                    </button>\n                  </div>\n                </div>\n              );\n            })}\n          </div>\n        \n\n        {/* ROW 1: POWERUPS DIRECT STORES & GACHA MACHINE WRAPPER */}\n        <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-8 text-left animate-pop\">\n          \n          {/* THE GILDED SCHOLAR MYSTERY GACHA BOX MACHINE */}\n          <div className=\"lg:col-span-5 bg-gradient-to-b from-indigo-950 to-slate-950 border-4 border-indigo-500 rounded-[32px] p-6 text-white flex flex-col justify-between space-y-6 relative shadow-lg overflow-hidden min-h-[420px]\">\n            {/* Ambient Background Grid lines */}\n            <div className=\"absolute inset-0 bg-[radial-gradient(#ffffff0a_1px,transparent_1px)] [background-size:16px_16px] pointer-events-none\"></div>\n\n            <div className=\"relative space-y-2\">\n              <div className=\"flex flex-wrap items-center gap-1.5\">\n                <span className=\"text-[9px] bg-indigo-500/30 text-indigo-300 border border-indigo-400/30 px-2 py-0.5 rounded-full font-mono font-bold uppercase tracking-widest\">\n                  🎰 Gilded Scholar Wheel\n                </span>\n                <span className=\"text-[9px] bg-amber-500/20 text-amber-300 border border-amber-400/20 px-2 py-0.5 rounded-full font-mono font-bold uppercase\">\n                  Mystery Drop\n                </span>\n              </div>\n              <h3 className=\"font-display font-black text-xl text-[#f3f4f6] tracking-tight flex items-center gap-1.5 uppercase\">\n                <Boxes className=\"w-5 h-5 text-indigo-400\" />\n                Sovereign Mystery Box\n              </h3>\n              <p className=\"text-slate-300 text-[11px] leading-relaxed\">\n                Unlock high-end exclusive monickers flairs, custom avatar seeds, directly cashbacks, or valuable quiz helpers! Costs <strong className=\"text-amber-400\">120 GEMS</strong>.\n              </p>\n            </div>\n\n            {/* Simulated Live Roll Panel */}\n            <div className=\"relative bg-slate-900/90 border border-indigo-500/40 rounded-2xl p-5 min-h-[140px] flex flex-col items-center justify-center text-center space-y-3 shadow-inner\">\n              {isRollingGacha ? (\n                <div className=\"space-y-3 animate-pulse\">\n                  <div className=\"w-12 h-12 bg-indigo-600/30 border-2 border-indigo-500 rounded-full flex items-center justify-center mx-auto text-xl animate-spin text-white\">\n                    <RefreshCw className=\"w-5 h-5\" />\n                  </div>\n                  <div>\n                    <span className=\"text-xs font-mono font-bold tracking-widest text-indigo-350 uppercase block\">Rerouting Cryptographic Seed...</span>\n                    <span className=\"text-[9px] text-slate-400\">Verifying on-chain math calibration blocks</span>\n                  </div>\n                </div>\n              ) : gachaResult ? (\n                <div className=\"space-y-2 animate-pop\">\n                  <div className=\"w-14 h-14 bg-amber-500/20 border-2 border-amber-400 rounded-full flex items-center justify-center mx-auto text-3xl shadow-sm\">\n                    {gachaResult.icon}\n                  </div>\n                  <div>\n                    <span className=\"text-[9px] bg-amber-500 text-slate-950 font-black font-mono px-2 py-0.5 rounded uppercase tracking-wider\">\n                      {gachaResult.badge}\n                    </span>\n                    <h4 className=\"font-display font-black text-sm text-amber-300 uppercase tracking-tight mt-1\">{gachaResult.name}</h4>\n                    <p className=\"text-[10px] text-slate-300\">{gachaResult.description}</p>\n                  </div>\n                </div>\n              ) : (\n                <div className=\"space-y-2\">\n                  <div className=\"w-12 h-12 bg-indigo-500/10 border border-indigo-500/20 text-indigo-405 rounded-full flex items-center justify-center mx-auto text-2xl\">\n                    🎁\n                  </div>\n                  <div>\n                    <span className=\"text-xs text-indigo-305 font-bold block uppercase tracking-wider font-mono\">Roll Terminal Ready</span>\n                    <span className=\"text-[10px] text-slate-400 leading-tight block max-w-xs\">Press button below to execute cryptographic spin. Double payouts guaranteed.</span>\n                  </div>\n                </div>\n              )}\n\n              {gachaError && (\n                <div className=\"text-[10px] text-rose-300 bg-rose-950/40 border border-rose-900 p-2 rounded-xl animate-pop\">\n                  {gachaError}\n                </div>\n              )}\n            </div>\n\n            <button\n              onClick={handleRollGacha}\n              disabled={isRollingGacha || user.gems < 120}\n              className={`w-full py-3 rounded-xl font-bold uppercase tracking-widest text-[11px] transition-all border-b-4 flex items-center justify-center gap-2 cursor-pointer ${\n                isRollingGacha\n                  ? \"bg-indigo-950 text-indigo-700 border-indigo-900 cursor-not-allowed\"\n                  : user.gems < 120\n                  ? \"bg-slate-800 text-slate-500 border-slate-900 cursor-not-allowed opacity-60\"\n                  : \"bg-indigo-500 hover:bg-indigo-400 text-white border-indigo-700 active:border-b-0 active:translate-y-0.5\"\n              }`}\n            >\n              <Sparkles className=\"w-4 h-4 text-amber-300 fill-amber-300\" />\n              Spin Machine (120 💎)\n            </button>\n          </div>\n\n          \n          {/* THE STRATEGIC POWER-UP SHOP DEPOT */}\n          <div className=\"lg:col-span-12 bg-white border border-slate-200 rounded-[32px] p-6 space-y-6 flex flex-col justify-between\">\n            <div className=\"space-y-1\">\n              <span className=\"text-[9px] bg-indigo-50 border border-indigo-200 text-indigo-700 px-2.5 py-1 rounded-full font-bold uppercase tracking-wider font-mono\">\n                ⚡ Tactical Booster Depot\n              </span>\n              <h3 className=\"font-display font-black text-xl text-slate-900 tracking-tight\">\n                Secure Live Quiz Power-Ups\n              </h3>\n              <p className=\"text-slate-500 text-[11px] leading-relaxed\">\n                Trade your acquired Sublime Gems to resupply your operational inventory stash! The rarer the gem used, the more high-powered quiz boosters you manifest at once.\n              </p>\n            </div>\n\n            <div className=\"grid grid-cols-1 md:grid-cols-3 gap-6 pt-1.5\">\n              \n              {/* Power-up item 1 */}\n              <div className=\"bg-slate-50 border border-slate-200 hover:border-amber-300 p-4 rounded-2xl flex flex-col justify-between transition h-full\">\n                <div className=\"space-y-2 text-left mb-4\">\n                  <div className=\"flex items-center justify-between\">\n                    <span className=\"font-bold text-sm text-slate-800\">50/50 Eliminator</span>\n                    <span className=\"text-[10px] px-2 py-1 bg-amber-50 text-amber-700 font-bold rounded border border-amber-200 font-mono\">\n                      Owned: {user.unlockedItems?.filter(x => x === 'powerup_50_50').length || 0}\n                    </span>\n                  </div>\n                  <p className=\"text-xs text-slate-500 min-h-[40px]\">Eliminates exactly two incorrect answers from standard multiple choice quiz arrays.</p>\n                </div>\n                \n                <div className=\"grid grid-cols-2 gap-2 mt-auto\">\n                  <button onClick={() => handleTradeGemForPowerup('trophy_gem_jade', 'powerup_50_50', '50/50')} disabled={vaultLoading !== null || !user.unlockedItems?.includes('trophy_gem_jade')} className=\"p-2 border rounded-xl text-[10px] font-bold font-mono transition flex flex-col items-center gap-1 bg-white border-emerald-200 hover:bg-emerald-50 text-emerald-800 disabled:opacity-50\">\n                    <Gem className=\"w-4 h-4 fill-emerald-500 text-emerald-500\" />\n                    <span>Pay 1 Jade (x1)</span>\n                  </button>\n                  <button onClick={() => handleTradeGemForPowerup('trophy_gem_sapphire', 'powerup_50_50', '50/50')} disabled={vaultLoading !== null || !user.unlockedItems?.includes('trophy_gem_sapphire')} className=\"p-2 border rounded-xl text-[10px] font-bold font-mono transition flex flex-col items-center gap-1 bg-white border-blue-200 hover:bg-blue-50 text-blue-800 disabled:opacity-50\">\n                    <Gem className=\"w-4 h-4 fill-blue-500 text-blue-500\" />\n                    <span>Pay 1 Sapphire (x3)</span>\n                  </button>\n                  <button onClick={() => handleTradeGemForPowerup('trophy_gem_ruby', 'powerup_50_50', '50/50')} disabled={vaultLoading !== null || !user.unlockedItems?.includes('trophy_gem_ruby')} className=\"p-2 border rounded-xl text-[10px] font-bold font-mono transition flex flex-col items-center gap-1 bg-white border-rose-200 hover:bg-rose-50 text-rose-800 disabled:opacity-50\">\n                    <Gem className=\"w-4 h-4 fill-rose-500 text-rose-500\" />\n                    <span>Pay 1 Ruby (x7)</span>\n                  </button>\n                  <button onClick={() => handleTradeGemForPowerup('trophy_gem_obsidian', 'powerup_50_50', '50/50')} disabled={vaultLoading !== null || !user.unlockedItems?.includes('trophy_gem_obsidian')} className=\"p-2 border rounded-xl text-[10px] font-bold font-mono transition flex flex-col items-center gap-1 bg-white border-purple-200 hover:bg-purple-50 text-purple-800 disabled:opacity-50\">\n                    <Gem className=\"w-4 h-4 fill-purple-600 text-purple-600\" />\n                    <span>Pay 1 Obsidian (x15)</span>\n                  </button>\n                </div>\n              </div>\n\n              {/* Power-up item 2 */}\n              <div className=\"bg-slate-50 border border-slate-200 hover:border-indigo-300 p-4 rounded-2xl flex flex-col justify-between transition h-full\">\n                <div className=\"space-y-2 text-left mb-4\">\n                  <div className=\"flex items-center justify-between\">\n                    <span className=\"font-bold text-sm text-slate-800\">Aegis Second Life</span>\n                    <span className=\"text-[10px] px-2 py-1 bg-indigo-50 text-indigo-700 font-bold rounded border border-indigo-200 font-mono\">\n                      Owned: {user.unlockedItems?.filter(x => x === 'powerup_extra_life').length || 0}\n                    </span>\n                  </div>\n                  <p className=\"text-xs text-slate-500 min-h-[40px]\">Shield absorbs one faulty calculation entry error penalty in active level quizzes.</p>\n                </div>\n                \n                <div className=\"grid grid-cols-2 gap-2 mt-auto\">\n                  <button onClick={() => handleTradeGemForPowerup('trophy_gem_jade', 'powerup_extra_life', 'Extra Life')} disabled={vaultLoading !== null || !user.unlockedItems?.includes('trophy_gem_jade')} className=\"p-2 border rounded-xl text-[10px] font-bold font-mono transition flex flex-col items-center gap-1 bg-white border-emerald-200 hover:bg-emerald-50 text-emerald-800 disabled:opacity-50\">\n                    <Gem className=\"w-4 h-4 fill-emerald-500 text-emerald-500\" />\n                    <span>Pay 1 Jade (x1)</span>\n                  </button>\n                  <button onClick={() => handleTradeGemForPowerup('trophy_gem_sapphire', 'powerup_extra_life', 'Extra Life')} disabled={vaultLoading !== null || !user.unlockedItems?.includes('trophy_gem_sapphire')} className=\"p-2 border rounded-xl text-[10px] font-bold font-mono transition flex flex-col items-center gap-1 bg-white border-blue-200 hover:bg-blue-50 text-blue-800 disabled:opacity-50\">\n                    <Gem className=\"w-4 h-4 fill-blue-500 text-blue-500\" />\n                    <span>Pay 1 Sapphire (x3)</span>\n                  </button>\n                  <button onClick={() => handleTradeGemForPowerup('trophy_gem_ruby', 'powerup_extra_life', 'Extra Life')} disabled={vaultLoading !== null || !user.unlockedItems?.includes('trophy_gem_ruby')} className=\"p-2 border rounded-xl text-[10px] font-bold font-mono transition flex flex-col items-center gap-1 bg-white border-rose-200 hover:bg-rose-50 text-rose-800 disabled:opacity-50\">\n                    <Gem className=\"w-4 h-4 fill-rose-500 text-rose-500\" />\n                    <span>Pay 1 Ruby (x7)</span>\n                  </button>\n                  <button onClick={() => handleTradeGemForPowerup('trophy_gem_obsidian', 'powerup_extra_life', 'Extra Life')} disabled={vaultLoading !== null || !user.unlockedItems?.includes('trophy_gem_obsidian')} className=\"p-2 border rounded-xl text-[10px] font-bold font-mono transition flex flex-col items-center gap-1 bg-white border-purple-200 hover:bg-purple-50 text-purple-800 disabled:opacity-50\">\n                    <Gem className=\"w-4 h-4 fill-purple-600 text-purple-600\" />\n                    <span>Pay 1 Obsidian (x15)</span>\n                  </button>\n                </div>\n              </div>\n\n              {/* Power-up item 3 */}\n              <div className=\"bg-slate-50 border border-slate-200 hover:border-emerald-300 p-4 rounded-2xl flex flex-col justify-between transition h-full\">\n                <div className=\"space-y-2 text-left mb-4\">\n                  <div className=\"flex items-center justify-between\">\n                    <span className=\"font-bold text-sm text-slate-800\">Temporal Hourglass</span>\n                    <span className=\"text-[10px] px-2 py-1 bg-emerald-50 text-emerald-700 font-bold rounded border border-emerald-200 font-mono\">\n                      Owned: {user.unlockedItems?.filter(x => x === 'powerup_extra_time').length || 0}\n                    </span>\n                  </div>\n                  <p className=\"text-xs text-slate-500 min-h-[40px]\">Increments exam limits or cancels stress so you can deliberate with ease.</p>\n                </div>\n                \n                <div className=\"grid grid-cols-2 gap-2 mt-auto\">\n                  <button onClick={() => handleTradeGemForPowerup('trophy_gem_jade', 'powerup_extra_time', 'Extra Time')} disabled={vaultLoading !== null || !user.unlockedItems?.includes('trophy_gem_jade')} className=\"p-2 border rounded-xl text-[10px] font-bold font-mono transition flex flex-col items-center gap-1 bg-white border-emerald-200 hover:bg-emerald-50 text-emerald-800 disabled:opacity-50\">\n                    <Gem className=\"w-4 h-4 fill-emerald-500 text-emerald-500\" />\n                    <span>Pay 1 Jade (x1)</span>\n                  </button>\n                  <button onClick={() => handleTradeGemForPowerup('trophy_gem_sapphire', 'powerup_extra_time', 'Extra Time')} disabled={vaultLoading !== null || !user.unlockedItems?.includes('trophy_gem_sapphire')} className=\"p-2 border rounded-xl text-[10px] font-bold font-mono transition flex flex-col items-center gap-1 bg-white border-blue-200 hover:bg-blue-50 text-blue-800 disabled:opacity-50\">\n                    <Gem className=\"w-4 h-4 fill-blue-500 text-blue-500\" />\n                    <span>Pay 1 Sapphire (x3)</span>\n                  </button>\n                  <button onClick={() => handleTradeGemForPowerup('trophy_gem_ruby', 'powerup_extra_time', 'Extra Time')} disabled={vaultLoading !== null || !user.unlockedItems?.includes('trophy_gem_ruby')} className=\"p-2 border rounded-xl text-[10px] font-bold font-mono transition flex flex-col items-center gap-1 bg-white border-rose-200 hover:bg-rose-50 text-rose-800 disabled:opacity-50\">\n                    <Gem className=\"w-4 h-4 fill-rose-500 text-rose-500\" />\n                    <span>Pay 1 Ruby (x7)</span>\n                  </button>\n                  <button onClick={() => handleTradeGemForPowerup('trophy_gem_obsidian', 'powerup_extra_time', 'Extra Time')} disabled={vaultLoading !== null || !user.unlockedItems?.includes('trophy_gem_obsidian')} className=\"p-2 border rounded-xl text-[10px] font-bold font-mono transition flex flex-col items-center gap-1 bg-white border-purple-200 hover:bg-purple-50 text-purple-800 disabled:opacity-50\">\n                    <Gem className=\"w-4 h-4 fill-purple-600 text-purple-600\" />\n                    <span>Pay 1 Obsidian (x15)</span>\n                  </button>\n                </div>\n              </div>\n\n            </div>\n          </div>\n</div>\n\n        \n\n        ",
  "part3": "\n        <div id=\"sublime-themed-vault-card\" className=\"bg-white border border-slate-200 rounded-[32px] p-6 space-y-6 text-left animate-pop\">\n          <div className=\"flex flex-col md:flex-row items-start md:items-center justify-between gap-4 border-b border-slate-100 pb-4\">\n            <div className=\"space-y-1 max-w-2xl\">\n              <span className=\"text-[9px] bg-emerald-50 border border-emerald-200 text-emerald-700 px-2.5 py-1 rounded-full font-bold uppercase tracking-wider font-mono flex items-center gap-1 w-fit\">\n                <Trophy className=\"w-3.5 h-3.5 text-emerald-600 fill-emerald-500\" />\n                Themed Reward Vault\n              </span>\n              <h3 className=\"font-display font-black text-2xl text-slate-900 tracking-tight\">\n                Sublime Gem Trade-Up Vault\n              </h3>\n              <p className=\"text-slate-500 text-xs\">\n                Provide yourself with long-term academic milestones. Convert standard accumulated gems into prestigious Rare and Legendary tokens. Displays prominently inside your trophy cabinets.\n              </p>\n            </div>\n\n            {/* Display collected items summary cabinet */}\n            <div className=\"bg-slate-50 border border-slate-200 rounded-2xl p-4 flex gap-4 text-center\">\n              <div>\n                <span className=\"text-[8px] font-bold text-slate-400 block uppercase font-mono\">Jade</span>\n                <span className=\"font-mono text-base font-black text-emerald-600\">\n                  {user.unlockedItems?.filter(x => x === 'trophy_gem_jade').length || 0}x\n                </span>\n              </div>\n              <div className=\"border-l border-slate-200\"></div>\n              <div>\n                <span className=\"text-[8px] font-bold text-slate-400 block uppercase font-mono\">Sapphire</span>\n                <span className=\"font-mono text-base font-black text-blue-600\">\n                  {user.unlockedItems?.filter(x => x === 'trophy_gem_sapphire').length || 0}x\n                </span>\n              </div>\n              <div className=\"border-l border-slate-200\"></div>\n              <div>\n                <span className=\"text-[8px] font-bold text-slate-400 block uppercase font-mono\">Ruby</span>\n                <span className=\"font-mono text-base font-black text-rose-600\">\n                  {user.unlockedItems?.filter(x => x === 'trophy_gem_ruby').length || 0}x\n                </span>\n              </div>\n              <div className=\"border-l border-slate-200\"></div>\n              <div>\n                <span className=\"text-[8px] font-bold text-slate-400 block uppercase font-mono\">Obsidian</span>\n                <span className=\"font-mono text-base font-black text-purple-650\">\n                  {user.unlockedItems?.filter(x => x === 'trophy_gem_obsidian').length || 0}x\n                </span>\n              </div>\n            </div>\n          </div>\n\n          {vaultSuccess && (\n            <div className=\"p-4 bg-emerald-50 border border-emerald-200 text-emerald-800 rounded-2xl text-xs flex items-center gap-2.5 animate-pop\">\n              <ShieldCheck className=\"w-5 h-5 text-emerald-600 flex-shrink-0\" />\n              <span className=\"font-semibold\">{vaultSuccess}</span>\n            </div>\n          )}\n\n          {vaultError && (\n            <div className=\"p-4 bg-rose-50 border border-rose-200 text-rose-800 rounded-2xl text-xs flex items-center gap-2.5 animate-pop\">\n              <AlertCircle className=\"w-5 h-5 text-rose-600 flex-shrink-0\" />\n              <span className=\"font-semibold\">{vaultError}</span>\n            </div>\n          )}\n\n          <div className=\"grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-4 pt-1\">\n            {tradeTiers.map(tier => {\n              const count = user.unlockedItems?.filter(x => x === tier.id).length || 0;\n              const hasBoughtBadge = count > 0;\n              const canAfford = user.gems >= tier.price;\n\n              return (\n                <div\n                  key={tier.id}\n                  className={`p-4 border rounded-2xl flex flex-col justify-between gap-4 transition-all duration-200 ${tier.bgColor} ${\n                    hasBoughtBadge ? \"shadow-sm border-slate-300\" : \"border-slate-205 bg-white\"\n                  }`}\n                >\n                  <div className=\"space-y-2\">\n                    <div className=\"flex items-center justify-between gap-2\">\n                      <span className=\"text-[8px] font-mono font-bold bg-slate-100 text-slate-600 px-1.5 py-0.5 rounded truncate\">\n                        {tier.badge}\n                      </span>\n                      <span className=\"font-mono text-[9px] font-bold bg-slate-105 text-slate-500 px-1.5 py-0.5 rounded shrink-0\">\n                        Owned: {count}\n                      </span>\n                    </div>\n\n                    <div className=\"flex gap-2 items-center\">\n                      <Gem className={`w-6 h-6 shrink-0 ${tier.iconColor}`} />\n                      <h4 className=\"font-display font-black text-[11px] text-slate-900 uppercase\">\n                        {tier.name}\n                      </h4>\n                    </div>\n\n                    <p className=\"text-slate-500 text-[10px] leading-relaxed\">\n                      {tier.desc}\n                    </p>\n                  </div>\n\n                  <div className=\"pt-2 border-t border-slate-100 flex flex-col gap-2\">\n                    <button\n                      type=\"button\"\n                      onClick={() => tradeTrophiesGems(tier)}\n                      disabled={vaultLoading !== null || !canAfford}\n                      className={`w-full py-2 text-[10px] font-extrabold font-mono uppercase tracking-wider rounded-xl transition flex items-center justify-center gap-1 border-b-2 cursor-pointer ${\n                        !canAfford\n                          ? \"bg-stone-50 border-stone-200 text-stone-400 cursor-not-allowed border-b\"\n                          : \"bg-amber-50 hover:bg-amber-100 text-amber-700 border-amber-200\"\n                      }`}\n                    >\n                      {vaultLoading === tier.id ? (\n                        <RefreshCw className=\"w-3 h-3 animate-spin\" />\n                      ) : (\n                        <>\n                          <Coins className=\"w-3.5 h-3.5 text-amber-600 fill-amber-500\" />\n                          Trade {tier.price} 💎\n                        </>\n                      )}\n                    </button>\n                  </div>\n                </div>\n              );\n            })}\n          </div>\n        \n\n        </div>\n\n      </div>\n\n      </div>\n\n      </div>\n\n      {/* INTERACTIVE CERTIFICATE MODAL */}\n      {showCertificateModal && (\n        <div \n          onClick={() => setShowCertificateModal(false)}\n          className=\"fixed inset-0 bg-slate-950/80 backdrop-blur-sm flex justify-center items-start overflow-y-auto z-[100] p-4 md:p-6 animate-fade-in\"\n        >\n          <div \n            onClick={(e) => e.stopPropagation()}\n            className=\"bg-white border border-slate-200 rounded-3xl w-full max-w-2xl shadow-2xl flex flex-col relative animate-pop text-left my-auto\"\n          >\n            <button\n              onClick={() => setShowCertificateModal(false)}\n              className=\"absolute top-4 right-4 p-2 text-slate-400 hover:text-slate-600 hover:bg-slate-100 rounded-full transition cursor-pointer z-10\"\n              title=\"Close Certificate\"\n            >\n              <X className=\"w-5 h-5\" />\n            </button>\n\n            {/* Certificate Sheet Display */}\n            <div className=\"p-8 md:p-12 text-center bg-[#fdfcfa] border-8 border-double border-[#d4af37] m-4 rounded-2xl flex flex-col items-center justify-center space-y-6 relative select-none\">\n              <div className=\"absolute top-4 left-4 text-[10px] text-stone-400 font-mono tracking-widest uppercase\">\n                SECURE CRID: SIG-{(user.uid || \"anon\").substring(4, 10).toUpperCase()}\n              </div>\n\n              <div className=\"space-y-2\">\n                <span className=\"text-xl font-serif font-black text-[#8c783c] tracking-widest uppercase block font-medium\">\n                  SIGMA ACADEMIC BOARD\n                </span>\n                <span className=\"text-[9px] font-mono font-bold text-slate-500 uppercase tracking-widest block\">\n                  curriculum calibration ledger validation\n                </span>\n              </div>\n\n              <div className=\"w-fit mx-auto border-b border-[#d4af37]/40 pb-2 mb-2\">\n                <h4 className=\"font-serif font-medium text-2.5xl md:text-3xl text-stone-900 italic tracking-wide\">\n                  Certificate of Academic Excellence\n                </h4>\n              </div>\n\n              <div className=\"space-y-4 max-w-md mx-auto font-sans\">\n                <p className=\"text-xs text-stone-600 tracking-wide\">\n                  This official document serves to verify the satisfactory fulfillment of rigorous, graduate-level coursework models in quantitative analyses. Scribed and credentialed unto:\n                </p>\n\n                <div className=\"py-2\">\n                  <h3 className=\"font-serif font-black text-2xl md:text-3xl text-[#1a2530] border-b-2 border-stone-800 w-fit mx-auto px-6 uppercase tracking-wider\">\n                    {user.username}\n                  </h3>\n                  <span className=\"text-[10px] text-stone-500 mt-1 block font-bold\">\n                    Registered Learner: {user.email}\n                  </span>\n                </div>\n\n                <p className=\"text-[11px] text-stone-600 leading-relaxed\">\n                  The aforementioned scholar has compiled perfect star evaluations, maintained daily streak habits, and unlocked math modeling tracks covering asset valuations, double-entry financial accounting, and compounding interest models.\n                </p>\n              </div>\n\n              {/* Gold seal stamp, signature, date */}\n              <div className=\"grid grid-cols-3 gap-4 items-center w-full pt-6 border-t border-stone-200\">\n                <div className=\"text-left space-y-1\">\n                  <span className=\"text-[9px] text-stone-400 font-mono uppercase block\">DATED SECURED</span>\n                  <span className=\"text-xs font-mono font-semibold text-stone-800\">\n                    {new Date(user.createdAt).toLocaleDateString()}\n                  </span>\n                </div>\n\n                {/* Gold Embossed Seal Vector */}\n                <div className=\"flex justify-center\">\n                  <div className=\"w-16 h-16 rounded-full bg-gradient-to-br from-yellow-300 via-amber-400 to-[#d4af37] flex items-center justify-center shadow-md relative border border-[#b29631]\">\n                    <div className=\"absolute inset-1 rounded-full border-2 border-dashed border-[#fdfcfa]/45\"></div>\n                    <Award className=\"w-8 h-8 text-neutral-900\" />\n                    <span className=\"absolute -bottom-1 bg-amber-900 text-white font-mono font-extrabold text-[8px] px-1 py-0.5 rounded tracking-widest uppercase\">\n                      VERIFIED\n                    </span>\n                  </div>\n                </div>\n\n                <div className=\"text-right space-y-1\">\n                  <span className=\"text-[9px] text-stone-400 font-mono uppercase block\">SECURE SIGNATURE</span>\n                  <span className=\"text-xs font-serif italic font-semibold text-stone-800 tracking-wide block\">\n                    Σ. Bookkeeper\n                  </span>\n                  <span className=\"text-[8px] text-stone-400 font-mono uppercase block\">Syllabus Director</span>\n                </div>\n              </div>\n\n              {/* Verification string */}\n              <div className=\"pt-4 text-center\">\n                <span className=\"text-[8px] font-mono text-stone-400 leading-relaxed max-w-xs block mx-auto font-bold uppercase tracking-wider\">\n                  CERTIFIER LEDGER TRANSPORT HASH:<br />\n                  SHA-255: SIG-{generateHash(user.uid || \"salt\")}-{generateHash(user.createdAt || \"time\")}\n                </span>\n              </div>\n            </div>\n\n            <div className=\"p-4 bg-slate-50 border-t border-slate-100 flex items-center justify-end gap-3\">\n              <button\n                onClick={() => setShowCertificateModal(false)}\n                className=\"px-5 py-2.5 bg-slate-100 hover:bg-slate-200 text-slate-700 text-xs font-extrabold uppercase tracking-wider rounded-xl transition cursor-pointer\"\n              >\n                Go Back\n              </button>\n              <button\n                onClick={() => {\n                  window.print();\n                }}\n                className=\"px-5 py-2.5 bg-slate-900 hover:bg-indigo-600 text-white text-xs font-extrabold uppercase tracking-wider rounded-xl transition cursor-pointer\"\n              >\n                Print Verification Certificate\n              </button>\n            </div>\n          </div>\n        </div>\n      )}\n\n      {user.tier === 'scholar' && (\n        <div className=\"pt-6 border-t border-slate-200 mt-10\">\n          <SponsorAdBanner \n            placement=\"store\" \n          />\n        </div>\n      )}\n    </div>\n  );\n}\n"
}